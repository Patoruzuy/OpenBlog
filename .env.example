# ─── Required ─────────────────────────────────────────────────────────────────
# Flask environment: development | staging | production | testing
ENV=development

# Must be a long random string in production (e.g. `openssl rand -hex 32`)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# PostgreSQL connection string
# Docker:  postgresql://openblog:openblog@db:5432/openblog
# Local:   postgresql://openblog:openblog@localhost:5432/openblog
DATABASE_URL=postgresql://openblog:openblog@db:5432/openblog

# Redis connection string — feeds Celery broker, result backend, and cache
# Docker: redis://redis:6379/0
# Local:  redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# Canonical public base URL (no trailing slash)
# Used for absolute URLs in feeds, sitemaps, invite links, and meta tags.
# Docker / local: http://localhost:7080
# Production:     https://yourdomain.com
PUBLIC_BASE_URL=http://localhost:7080

# ─── Derived (do NOT set manually) ────────────────────────────────────────────
# CELERY_BROKER_URL    → automatically set to REDIS_URL by config.py
# CELERY_RESULT_BACKEND → automatically set to REDIS_URL by config.py

# ─── Seed / demo credentials (development only) ───────────────────────────────
# Run `flask --app "backend.app:create_app()" seed` (or `make seed`) to create
# these accounts.  Never use these passwords in staging or production.
#
# Admin user
#   Email:    admin@openblog.dev
#   Password: admin1234
#   Role:     admin
#
# Contributor user
#   Email:    alice@openblog.dev
#   Password: alice1234
#   Role:     contributor
