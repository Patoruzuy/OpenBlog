# ─── Required ─────────────────────────────────────────────────────────────────
# Flask environment: development | staging | production | testing
ENV=development

# Must be a long random string in production (e.g. `openssl rand -hex 32`)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# PostgreSQL connection string
# Docker:  postgresql://openblog:openblog@db:5432/openblog
# Local:   postgresql://openblog:openblog@localhost:5432/openblog
DATABASE_URL=postgresql://openblog:openblog@db:5432/openblog

# Redis connection string — feeds Celery broker, result backend, and cache
# Docker: redis://redis:6379/0
# Local:  redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ─── Derived (do NOT set manually) ────────────────────────────────────────────
# CELERY_BROKER_URL    → automatically set to REDIS_URL by config.py
# CELERY_RESULT_BACKEND → automatically set to REDIS_URL by config.py
