# ─── Local development overrides ──────────────────────────────────────────────
#
# Copy this file to .env.local for running `flask run` directly on your host
# machine (outside Docker).  python-dotenv loads both .env and .env.local;
# values in .env.local take precedence.
#
# NEVER commit .env.local — it is listed in .gitignore.
#
# Usage:
#   cp .env.local.example .env.local
#   flask --app "backend.app:create_app()" run

# Override Docker service hostnames with localhost equivalents
DATABASE_URL=postgresql://openblog:openblog@localhost:5432/openblog
REDIS_URL=redis://localhost:6379/0
