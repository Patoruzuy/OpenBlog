msgstr "Aún no hay temas."

msgid "Start writing posts and add tags to create topics."
msgstr "Empieza a escribir artículos y añade etiquetas para crear temas."

msgid "Routing, blueprints, deployment, and real-world patterns."
msgstr "Enrutamiento, blueprints, despliegue y patrones del mundo real."

msgid "Language features, tooling, packaging, and ecosystem notes."
msgstr "Características del lenguaje, herramientas, empaquetado y notas del ecosistema."

msgid "Queries, indexing, full-text search, and migrations."
msgstr "Consultas, indexación, búsqueda de texto completo y migraciones."

msgid "Task queues, beat scheduling, and worker configuration."
msgstr "Colas de tareas, programación beat y configuración de workers."

msgid "Caching, queuing, pub/sub, and persistence patterns."
msgstr "Caché, colas, pub/sub y patrones de persistencia."

msgid "Containerisation, Compose, and production Dockerfiles."
msgstr "Contenedores, Compose y Dockerfiles de producción."

msgid "Shell scripting, system administration, and tooling."
msgstr "Scripting de shell, administración de sistemas y herramientas."

msgid "Branching, rebasing, workflows, and repo management."
msgstr "Ramificación, rebase, flujos de trabajo y gestión de repositorios."

msgid "Queries, schema design, indexing, and optimisation."
msgstr "Consultas, diseño de esquemas, indexación y optimización."

msgid "REST design, versioning, auth, and documentation."
msgstr "Diseño REST, versionado, autenticación y documentación."

msgid "Unit tests, integration tests, fixtures, and coverage."
msgstr "Tests unitarios, tests de integración, fixtures y cobertura."

msgid "CI/CD pipelines, infrastructure, and deployment automation."
msgstr "Pipelines CI/CD, infraestructura y automatización del despliegue."

msgid "Auth patterns, input validation, secrets management."
msgstr "Patrones de autenticación, validación de entrada, gestión de secretos."

msgid "Language models, embeddings, retrieval, and practical ML."
msgstr "Modelos de lenguaje, embeddings, recuperación y ML práctico."

msgid "Browser JS, tooling, and small scripting patterns."
msgstr "JS de navegador, herramientas y patrones de scripting."

msgid "Type safety, configuration, and real-world usage."
msgstr "Seguridad de tipos, configuración y uso en el mundo real."

msgid "System design, service boundaries, and trade-offs."
msgstr "Diseño de sistemas, límites de servicios y compensaciones."

msgid "Recently improved"
msgstr "Recientemente mejorado"

msgid "Posts that got better through accepted community revisions."
msgstr "Artículos que mejoraron gracias a revisiones comunitarias aceptadas."

